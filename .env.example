# Corretor ZX Control — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env com valores reais.

# ── Negócio ──────────────────────────────────────────────────────────────────
CORRETOR_NOME=                         # Nome do corretor (aparece nas mensagens do WhatsApp)
GOOGLE_REVIEW_LINK=                    # Link de avaliação Google Minha Empresa do corretor

# ── WhatsApp — Evolution é o default deste pacote (spec §3.1) ────────────────
# Adapter é plugável: evolution | zapi | meta | uazapi
WHATSAPP_PROVIDER=evolution
EVOLUTION_URL=                         # ex: http://localhost:8080
EVOLUTION_INSTANCE=                    # nome da instância no painel Evolution
EVOLUTION_API_KEY=                     # AUTHENTICATION_API_KEY do .env da Evolution

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=                          # Supabase → Project Settings → API → Project URL
SUPABASE_SERVICE_KEY=                  # service_role key (secreta — nunca vai pro painel)

# ── Gemini Flash ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=                        # aistudio.google.com/apikey (free tier disponível)

# ── Painel (Cloudflare Pages) ────────────────────────────────────────────────
PANEL_TOKEN=                           # token Bearer que protege a API do painel — gere uma string forte

# ── Segurança do webhook ─────────────────────────────────────────────────────
# Registre o webhook no provider como: <WORKER_URL>/webhook
# com o header: x-webhook-secret: <WEBHOOK_SECRET>
WEBHOOK_SECRET=                        # gerado durante a instalação guiada
