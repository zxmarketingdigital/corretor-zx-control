EVOLUTION_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=
GOOGLE_REVIEW_LINK=
# registre o webhook no provider como <WORKER_URL>/webhook?token=<WEBHOOK_SECRET>
WEBHOOK_SECRET=
